POSTGRES_DB=elfor_staging
POSTGRES_USER=elfor
POSTGRES_PASSWORD=change-me-now
DATABASE_URL=postgres://elfor:change-me-now@postgres:5432/elfor_staging
ADMIN_PASSWORD=change-me-now
ADMIN_SESSION_SECRET=change-me-too

# Optional but recommended
LOG_LEVEL=info

# Optional: email notifications
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional: object storage for catalog/documents/invoices
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=

# Optional: local object storage for standard VPS deployments
LOCAL_OBJECT_STORAGE_DIR=/var/lib/elfor/object-storage
