FROM node:24-bookworm-slim AS build

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
ENV PORT=8080
ENV BASE_PATH=/

RUN corepack enable && corepack prepare pnpm@11.5.1 --activate

WORKDIR /app

COPY . .

RUN pnpm install --frozen-lockfile || (pnpm approve-builds --all && pnpm install --frozen-lockfile)
RUN pnpm --filter @workspace/elfor-store run build

FROM nginx:1.27-alpine

COPY deploy/nginx.staging.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/artifacts/elfor-store/dist/public /usr/share/nginx/html
